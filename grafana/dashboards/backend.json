{
  "title": "Backend Monitoring",
  "uid": "backend-monitoring",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "GPU Utilization",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "avg(nvidia_gpu_utilization{job=\"backend\"})",
          "legendFormat": "GPU {{gpu}}"
        }
      ],
      "options": {
        "min": 0,
        "max": 100,
        "unit": "percent"
      }
    },
    {
      "id": 2,
      "title": "Task Queue Length",
      "type": "graph",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "celery_queue_length{job=\"backend\"}",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "API Request Rate",
      "type": "graph",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"backend\"}[5m])",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ],
      "options": {
        "unit": "reqps"
      }
    },
    {
      "id": 4,
      "title": "Error Rate",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"backend\", status=~\"5..\"}[5m])",
          "legendFormat": "5xx errors"
        }
      ],
      "options": {
        "unit": "reqps"
      }
    },
    {
      "id": 5,
      "title": "Credit Usage",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "credit_usage_total{job=\"backend\"}",
          "legendFormat": "{{user}}"
        }
      ]
    }
  ]
}
